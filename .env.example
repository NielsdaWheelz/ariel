ARIEL_DATABASE_URL=postgresql+psycopg://ariel:change-me-dev@localhost:5433/ariel
ARIEL_DB_CONTAINER_NAME=ariel-postgres
ARIEL_DB_DOCKER_IMAGE=postgres:16-alpine
ARIEL_DB_VOLUME_NAME=ariel-postgres-data
ARIEL_MODEL_NAME=gpt-5.5
ARIEL_OPENAI_API_KEY=your_real_key
ARIEL_MODEL_REASONING_EFFORT=medium
ARIEL_MODEL_VERBOSITY=low
ARIEL_BIND_HOST=127.0.0.1
ARIEL_BIND_PORT=8000
ARIEL_MAX_RECENT_TURNS=12

# discord primary surface
# required: discord bot token; enable Message Content Intent in the Discord Developer Portal
ARIEL_DISCORD_BOT_TOKEN=
# required: one home guild/server id for owner guild-chat mode
ARIEL_DISCORD_GUILD_ID=
# required: default notification/thread parent channel id; not a one-channel chat gate
ARIEL_DISCORD_CHANNEL_ID=
# required: configured user id allowed to talk to Ariel
ARIEL_DISCORD_USER_ID=
# optional: ariel api base url used by the bot worker (default: http://127.0.0.1:8000)
ARIEL_DISCORD_ARIEL_BASE_URL=http://127.0.0.1:8000
# optional: Discord REST timeout for background notification delivery (default: 10.0)
ARIEL_DISCORD_NOTIFICATION_TIMEOUT_SECONDS=10.0

# attachment content extraction
# local blob store path for downloaded, scanned attachment bytes
ARIEL_ATTACHMENT_BLOB_STORE_PATH=.ariel/attachment-blobs
# max attachment bytes accepted for content reads
ARIEL_ATTACHMENT_MAX_BYTES=26214400
# timeout for Discord attachment downloads
ARIEL_ATTACHMENT_FETCH_TIMEOUT_SECONDS=10.0
# attachment download handles expire after this many seconds
ARIEL_ATTACHMENT_HANDLE_TTL_SECONDS=3600
# production default is fail-closed until a real scanner is configured
ARIEL_ATTACHMENT_SCANNER_MODE=fail_closed
# OpenAI model used for image and document extraction
ARIEL_ATTACHMENT_OPENAI_MODEL=gpt-5.5
# OpenAI model used for audio transcription
ARIEL_ATTACHMENT_OPENAI_AUDIO_MODEL=gpt-4o-transcribe
# timeout for OpenAI attachment extraction calls
ARIEL_ATTACHMENT_OPENAI_TIMEOUT_SECONDS=30.0

# agency daemon capabilities
ARIEL_AGENCY_SOCKET_PATH=/tmp/agency-daemon.sock
ARIEL_AGENCY_ALLOWED_REPO_ROOTS=/Users/you/Documents/code/ariel,/Users/you/Documents/code/agency
ARIEL_AGENCY_DEFAULT_BASE_BRANCH=main
ARIEL_AGENCY_DEFAULT_RUNNER=codex
ARIEL_AGENCY_TIMEOUT_SECONDS=30.0

# agency signed event ingress
# required to accept POST /v1/agency/events; leave blank to disable agency ingress
ARIEL_AGENCY_EVENT_SECRET=
# optional: accepted signature timestamp skew in seconds (default: 300)
ARIEL_AGENCY_EVENT_MAX_SKEW_SECONDS=300

# google provider webhook ingress
# required to accept POST /v1/providers/google/events; leave blank to disable provider ingress
ARIEL_GOOGLE_PROVIDER_EVENT_TOKEN=

# durable worker
# optional: idle polling interval in seconds (default: 1.0)
ARIEL_WORKER_POLL_SECONDS=1.0
# optional: running task heartbeat timeout in seconds (default: 300)
ARIEL_WORKER_HEARTBEAT_TIMEOUT_SECONDS=300

# search capabilities
# required for live cap.search.web/cap.search.news through web-search-tool Brave provider
ARIEL_SEARCH_WEB_API_KEY=
# optional: news falls back to web api key when blank/unset
# ARIEL_SEARCH_NEWS_API_KEY=
# optional provider overrides:
# ARIEL_SEARCH_BRAVE_BASE_URL=https://api.search.brave.com/res/v1
# ARIEL_SEARCH_WEB_TIMEOUT_SECONDS=8.0
# ARIEL_SEARCH_NEWS_TIMEOUT_SECONDS=8.0

# maps (slice-6 pr-02)
# encrypted api key expected (same connector keyring/cipher path as google connector secrets)
ARIEL_MAPS_PROVIDER_API_KEY_ENC=
# optional overrides:
# ARIEL_MAPS_PROVIDER_ENDPOINT=https://maps.googleapis.com/maps/api
# ARIEL_MAPS_PROVIDER_TIMEOUT_SECONDS=8.0

# web extract (slice-7 pr-01)
# api key optional; falls back to ARIEL_SEARCH_WEB_API_KEY when using brave extract
# ARIEL_WEB_EXTRACT_API_KEY=
# optional overrides:
# ARIEL_WEB_EXTRACT_PROVIDER_ENDPOINT=https://api.search.brave.com/res/v1/web/extract
# ARIEL_WEB_EXTRACT_TIMEOUT_SECONDS=10.0
# ARIEL_WEB_EXTRACT_MAX_RETRIES=2
