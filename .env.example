ARIEL_DATABASE_URL=postgresql+psycopg://ariel:change-me-dev@localhost:5433/ariel
ARIEL_DB_CONTAINER_NAME=ariel-postgres
ARIEL_DB_DOCKER_IMAGE=postgres:16-alpine
ARIEL_DB_VOLUME_NAME=ariel-postgres-data
ARIEL_MODEL_PROVIDER=openai
ARIEL_MODEL_NAME=gpt-4o-mini
ARIEL_MODEL_API_KEY=your_real_key
ARIEL_BIND_HOST=127.0.0.1
ARIEL_BIND_PORT=8000
ARIEL_MAX_RECENT_TURNS=12

# maps (slice-6 pr-02)
# encrypted api key expected (same connector keyring/cipher path as google connector secrets)
ARIEL_MAPS_PROVIDER_API_KEY_ENC=
# optional overrides:
# ARIEL_MAPS_PROVIDER_ENDPOINT=https://maps.googleapis.com/maps/api
# ARIEL_MAPS_PROVIDER_TIMEOUT_SECONDS=8.0
