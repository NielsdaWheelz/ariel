# Runtime config and dev helpers. Env prefix: ARIEL_.

# optional; default: postgresql+psycopg://localhost/ariel
ARIEL_DATABASE_URL=postgresql+psycopg://ariel:change-me-dev@localhost:5433/ariel
# optional; default: development; allowed: development, production
ARIEL_DEPLOYMENT_MODE=development
# optional; default: 127.0.0.1
ARIEL_BIND_HOST=127.0.0.1
# optional; default: 8000
ARIEL_BIND_PORT=8000
# optional; default: false
ARIEL_LOCAL_AUTH_REQUIRED=false
# required when ARIEL_LOCAL_AUTH_REQUIRED=true; must be 32+ URL-safe random chars
# generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# ARIEL_LOCAL_AUTH_TOKEN=

# required for model calls; default: unset
ARIEL_OPENAI_API_KEY=your_real_key
# optional; default: gpt-5.5
ARIEL_MODEL_NAME=gpt-5.5
# optional; default: 30.0
ARIEL_MODEL_TIMEOUT_SECONDS=30.0
# optional; default: medium; allowed: minimal, low, medium, high
ARIEL_MODEL_REASONING_EFFORT=medium
# optional; default: low; allowed: low, medium, high
ARIEL_MODEL_VERBOSITY=low
# optional; default: 700
ARIEL_MAX_RESPONSE_TOKENS=700
# optional; default: 2
ARIEL_MAX_MODEL_ATTEMPTS=2
# optional; default: 20000
ARIEL_MAX_TURN_WALL_TIME_MS=20000

# optional; default: 12
ARIEL_MAX_RECENT_TURNS=12
# optional; default: 8
ARIEL_MAX_RECALLED_ASSERTIONS=8
# optional; default: 6000
ARIEL_MAX_CONTEXT_TOKENS=6000
# optional; default: 120
ARIEL_AUTO_ROTATE_MAX_TURNS=120
# optional; default: 172800
ARIEL_AUTO_ROTATE_MAX_AGE_SECONDS=172800
# optional; default: 5400
ARIEL_AUTO_ROTATE_CONTEXT_PRESSURE_TOKENS=5400

# optional; default: openai
ARIEL_MEMORY_EMBEDDING_PROVIDER=openai
# optional; default: text-embedding-3-small
ARIEL_MEMORY_EMBEDDING_MODEL=text-embedding-3-small
# optional; default: 1536; must match schema
ARIEL_MEMORY_EMBEDDING_DIMENSIONS=1536
# optional; default: false; enables one-time cutover import surface
ARIEL_MEMORY_IMPORT_CUTOVER_ENABLED=false
# optional; default: 0.6; max pgvector cosine distance for the recall vector signal
ARIEL_MEMORY_VECTOR_DISTANCE_CEILING=0.6
# optional; default: 60; Reciprocal Rank Fusion k constant for hybrid recall
ARIEL_MEMORY_RRF_K=60
# optional; default: 12; candidate backlog size that triggers consolidation
ARIEL_MEMORY_CONSOLIDATION_CANDIDATE_THRESHOLD=12
# optional; default: 3; open-conflict backlog size that triggers consolidation
ARIEL_MEMORY_CONSOLIDATION_CONFLICT_THRESHOLD=3
# optional; default: 86400; scheduled consolidation cadence per scope, in seconds
ARIEL_MEMORY_CONSOLIDATION_INTERVAL_SECONDS=86400
# optional; default: 1500; hot-index rebuild evicts lowest-salience entries to fit this token budget
ARIEL_MEMORY_HOT_INDEX_BUDGET_TOKENS=1500
# optional; default: 2500; hard token cap for a rebuilt hot index; exceeding it is a defect
ARIEL_MEMORY_HOT_INDEX_HARD_MAX_TOKENS=2500
# optional; default: 0.25; consolidation demotes an assertion below this decayed value (in [0.0, 1.0])
ARIEL_MEMORY_FORGETTING_VALUE_FLOOR=0.25
# optional; default: 180; days unverified before consolidation may demote a low-value assertion
ARIEL_MEMORY_FORGETTING_STALENESS_DAYS=180

# optional; default: 900
ARIEL_APPROVAL_TTL_SECONDS=900
# optional; default: user.local
ARIEL_APPROVAL_ACTOR_ID=user.local

# required for Google connector; optional otherwise; default: unset
# ARIEL_GOOGLE_OAUTH_CLIENT_ID=
# required for Google connector; optional otherwise; default: unset
# ARIEL_GOOGLE_OAUTH_CLIENT_SECRET=
# optional; default: http://127.0.0.1:8000/v1/connectors/google/callback
ARIEL_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/v1/connectors/google/callback
# optional; default: 600
ARIEL_GOOGLE_OAUTH_STATE_TTL_SECONDS=600
# optional; default: 10.0
ARIEL_GOOGLE_OAUTH_TIMEOUT_SECONDS=10.0
# required for POST /v1/providers/google/events; optional otherwise; default: unset
# ARIEL_GOOGLE_PROVIDER_EVENT_TOKEN=

# optional in development; required non-default in production; default: dev-local-connector-secret
ARIEL_CONNECTOR_ENCRYPTION_SECRET=dev-local-connector-secret
# optional; default: v1
ARIEL_CONNECTOR_ENCRYPTION_KEY_VERSION=v1
# required in production; active version must exist in this keyring
# ARIEL_CONNECTOR_ENCRYPTION_KEYS=

# required for Discord surface; optional otherwise; default: unset
ARIEL_DISCORD_BOT_TOKEN=
# required for owner guild-chat mode; optional otherwise; default: unset
ARIEL_DISCORD_GUILD_ID=
# required for default notification/thread parent; optional otherwise; default: unset
ARIEL_DISCORD_CHANNEL_ID=
# required for configured owner user; optional otherwise; default: unset
ARIEL_DISCORD_USER_ID=
# optional; default: http://127.0.0.1:8000
ARIEL_DISCORD_ARIEL_BASE_URL=http://127.0.0.1:8000
# optional; default: 10.0
ARIEL_DISCORD_NOTIFICATION_TIMEOUT_SECONDS=10.0

# optional; default: .ariel/attachment-blobs
ARIEL_ATTACHMENT_BLOB_STORE_PATH=.ariel/attachment-blobs
# optional; default: 26214400
ARIEL_ATTACHMENT_MAX_BYTES=26214400
# optional; default: 10.0
ARIEL_ATTACHMENT_FETCH_TIMEOUT_SECONDS=10.0
# optional; default: 3600
ARIEL_ATTACHMENT_HANDLE_TTL_SECONDS=3600
# optional; default: fail_closed; allowed: disabled, fail_closed
ARIEL_ATTACHMENT_SCANNER_MODE=fail_closed
# optional; default: gpt-5.5
ARIEL_ATTACHMENT_OPENAI_MODEL=gpt-5.5
# optional; default: gpt-4o-transcribe
ARIEL_ATTACHMENT_OPENAI_AUDIO_MODEL=gpt-4o-transcribe
# optional; default: 30.0
ARIEL_ATTACHMENT_OPENAI_TIMEOUT_SECONDS=30.0

# optional; default: /tmp/agency-daemon.sock
ARIEL_AGENCY_SOCKET_PATH=/tmp/agency-daemon.sock
# optional; default: empty string
ARIEL_AGENCY_ALLOWED_REPO_ROOTS=/Users/you/Documents/code/ariel,/Users/you/Documents/code/agency
# optional; default: main
ARIEL_AGENCY_DEFAULT_BASE_BRANCH=main
# optional; default: codex
ARIEL_AGENCY_DEFAULT_RUNNER=codex
# optional; default: 30.0
ARIEL_AGENCY_TIMEOUT_SECONDS=30.0
# required for POST /v1/agency/events; optional otherwise; default: unset
# ARIEL_AGENCY_EVENT_SECRET=
# optional; default: 300
ARIEL_AGENCY_EVENT_MAX_SKEW_SECONDS=300

# optional; default: 1.0
ARIEL_WORKER_POLL_SECONDS=1.0
# optional; default: 300
ARIEL_WORKER_HEARTBEAT_TIMEOUT_SECONDS=300
# optional; default: 60; worker-owned ambient interpretation interval in seconds
ARIEL_PROACTIVE_AMBIENT_INTERVAL_SECONDS=60
# optional; default: 5
ARIEL_PROACTIVE_WORKER_MAX_ATTEMPTS=5
# optional; default: 2
ARIEL_PROACTIVE_DELIBERATION_TOOL_ROUNDS=2

# Dev database helper settings read by src/ariel/dev_db.py.

# optional; default: ariel-postgres
ARIEL_DB_CONTAINER_NAME=ariel-postgres
# optional; default: pgvector/pgvector:pg16
ARIEL_DB_DOCKER_IMAGE=pgvector/pgvector:pg16
# optional; default: <container-name>-data
ARIEL_DB_VOLUME_NAME=ariel-postgres-data

# Capability provider settings validated by AppSettings.

# required for live cap.search.web; optional otherwise; default: unset
# ARIEL_SEARCH_WEB_API_KEY=
# optional; default: https://api.search.brave.com/res/v1
# ARIEL_SEARCH_BRAVE_BASE_URL=https://api.search.brave.com/res/v1
# optional; default: 8.0
# ARIEL_SEARCH_WEB_TIMEOUT_SECONDS=8.0
# optional; default: unset; cap.search.news falls back to ARIEL_SEARCH_WEB_API_KEY
# ARIEL_SEARCH_NEWS_API_KEY=
# optional; default: 8.0
# ARIEL_SEARCH_NEWS_TIMEOUT_SECONDS=8.0

# optional; default: production; allowed: production, dev_fallback
# ARIEL_WEATHER_PROVIDER_MODE=production
# optional; default: https://api.tomorrow.io/v4/weather/forecast
# ARIEL_WEATHER_PRODUCTION_ENDPOINT=https://api.tomorrow.io/v4/weather/forecast
# required for production weather; optional otherwise; default: unset
# ARIEL_WEATHER_PRODUCTION_API_KEY=
# optional; default: 8.0
# ARIEL_WEATHER_PRODUCTION_TIMEOUT_SECONDS=8.0
# optional; default: https://wttr.in
# ARIEL_WEATHER_DEV_ENDPOINT=https://wttr.in
# optional; default: 8.0
# ARIEL_WEATHER_DEV_TIMEOUT_SECONDS=8.0
# optional; default: unset; seeded once when canonical state is unset
# ARIEL_WEATHER_DEFAULT_LOCATION=

# required for maps capabilities; optional otherwise; default: unset
# google maps platform key with routes api, places api (new), and geocoding api enabled
# ARIEL_MAPS_API_KEY=
# optional; default: 8.0
# ARIEL_MAPS_TIMEOUT_SECONDS=8.0

# optional; default: https://api.search.brave.com/res/v1/web/extract
# ARIEL_WEB_EXTRACT_PROVIDER_ENDPOINT=https://api.search.brave.com/res/v1/web/extract
# optional; default: 10.0
# ARIEL_WEB_EXTRACT_TIMEOUT_SECONDS=10.0
# optional; default: 2; max: 5
# ARIEL_WEB_EXTRACT_MAX_RETRIES=2
# optional; default: unset; falls back to ARIEL_SEARCH_WEB_API_KEY
# ARIEL_WEB_EXTRACT_API_KEY=
